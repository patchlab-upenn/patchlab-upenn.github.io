	doi = {10.1002/alz.13559},
	journal = {Alzheimers Dement},
	journal-full = {Alzheimer's \& dementia : the journal of the Alzheimer's Association},
	keywords = {Alzheimer's disease; aging; co-pathologies; multi-modality imaging; neurodegeneration; post mortem; tau},
	mesh = {Humans; Alzheimer Disease; tau Proteins; Resilience, Psychological; Neurofibrillary Tangles; Magnetic Resonance Imaging; Amyloid beta-Peptides},
	month = {Mar},
	number = {3},
	pages = {1586-1600},
	pmc = {PMC10984442},
	pmid = {38050662},
	pst = {ppublish},
	title = {Tau-neurodegeneration mismatch reveals vulnerability and resilience to comorbidities in Alzheimer's continuum},
	volume = {20},
	year = {2024},
