@article{sadaghiani2022associations2,
  title = {Associations between cortical microinfarcts, hippocampal atrophy, and cerebral small vessel disease},
  author = {S. Sadaghiani and Sudipto Dolui and Pulkit Khandelwal and M. Taghvaei and Banafsheh Shakibajahromi and Sandhitsu R. Das and Paul Yushkevich and D. Wolk and J. Detre},
  year = {2022},
  abstract = {Brain cortical microinfarcts (CMI) are negatively correlated with cognitive function in both normal aging and Alzheimer’s disease (AD). High‐field structural magnetic resonance imaging (MRI) has facilitated in vivo detection of CMIs but their significance and underlying pathological mechanism remain uncertain. Here we assessed correlations between CMIs and medial temporal lobe (MTL) cortical thickness, white matter hyperintensity (WMH) volume, and relative periventricular white matter cerebral blood flow (PVWM CBF) in healthy individuals. PVWM CBF is thought to provide a measure of cerebral small vessel function.},
  doi = {10.1002/alz.065574},
  month = {12},
  journal = {Alzheimer's & Dementia},
  volume = {18},
  google_scholar_id = {tn5kj04AAAAJ},
  altmetric = {true},
  dimensions = {true},
}

@article{sadaghiani2022linking,
  title = {Linking histology to post‐mortem 7T MRI measures of neurodegeneration},
  author = {S. Sadaghiani and S. Ravikumar and R. Ittyerah and Sydney A. Lim and E. Chung and M. Bedard and L. Xie and Sandhitsu R. Das and T. Schuck and M. Grossman and Eddie B. Lee and D. Tisdall and K. Prabhakaran and J. Detre and G. Mizsei and J. Trojanowski and D. Irwin and L. Wisse and D. Wolk and Paul Yushkevich},
  year = {2022},
  abstract = {Neurodegenerative disorders are associated with different pathologies that often co‐occur and have differential contribution to the pattern of cognitive impairment. The majority of these pathologies cannot be detected or measured by in‐vivo methods; therefore, recognition of the topographic patterns of them and association with MRI findings may provide probabilistic non‐invasive biomarkers. We investigated the association of cortical and medial temporal lobe subregional thickness measured from postmortem MRI and semi‐quantitative pathologic measures in order to provide a methodological approach for linking pathological and radiological measures.},
  doi = {10.1002/alz.066155},
  month = {12},
  journal = {Alzheimer's & Dementia},
  volume = {18},
  google_scholar_id = {tn5kj04AAAAJ},
  altmetric = {true},
  dimensions = {true},
}

@article{taghvaei2022mechanisms,
  title = {Mechanisms of Cognitive Decline due to White Matter Lesions in Cognitively Intact Older Adults},
  author = {M. Taghvaei and P. Cook and Pulkit Khandelwal and Banafsheh Shakibajahromi and S. Sadaghiani and Sandhitsu R. Das and Christopher A. Brown and William Tackett and Sudipto Dolui and R. Shinohara and D. Wolk and J. Detre},
  year = {2022},
  abstract = {White matter hyperintensities (WMH) on FLAIR MRI are highly prevalent in older adults and are linked to cognitive deficits as well as dementia. Likely mechanisms underlying associations between WMH and cognitive deficits include widespread partial disconnection due to the diffuse nature of progressive WMH and/or tract‐specific disconnection syndromes. We used a virtual lesion approach to evaluate cognitive deficits in domains associated with three tracts: left arcuate fasciculus (LAF; verbal working memory), inferior longitudinal fasciculus (ILF; visual processing), and fornix (memory).},
  doi = {10.1002/alz.069332},
  month = {12},
  journal = {Alzheimer's & Dementia},
  volume = {18},
  google_scholar_id = {tn5kj04AAAAJ},
  altmetric = {true},
  dimensions = {true},
}

