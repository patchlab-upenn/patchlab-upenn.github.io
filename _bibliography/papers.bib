	doi = {10.1093/cercor/bhw299},
	journal = {Cereb Cortex},
	journal-full = {Cerebral cortex (New York, N.Y. : 1991)},
	keywords = {MRI; hippocampus; in vivo; postmortem; subfields},
	mesh = {Aged; Aged, 80 and over; Brain Diseases; Female; Hippocampus; Humans; Image Processing, Computer-Assisted; Magnetic Resonance Imaging; Male; Middle Aged; Organ Size; Pattern Recognition, Automated; Phantoms, Imaging},
	month = {11},
