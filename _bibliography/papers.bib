@article{ravikumar2024postmortem,
  title = {Postmortem imaging reveals patterns of medial temporal lobe vulnerability to tau pathology in Alzheimer’s disease},
  author = {S. Ravikumar and Amanda E Denning and Sydney A. Lim and E. Chung and Niyousha Sadeghpour and R. Ittyerah and L. Wisse and Sandhitsu R. Das and L. Xie and J. Robinson and T. Schuck and Edward B. Lee and John A. Detre and M. Tisdall and K. Prabhakaran and G. Mizsei and Maria Mercedes Iñiguez de Onzoño Martin and María del Mar Arroyo Jiménez and M. Muñoz and María Del Pilar Marcos Rabal and S. Cebada Sánchez and J. C. Delgado González and C. de la Rosa Prieto and David J. Irwin and D. Wolk and R. Insausti and Paul Yushkevich},
  year = {2024},
  abstract = {Our current understanding of the spread and neurodegenerative effects of tau neurofibrillary tangles (NFTs) within the medial temporal lobe (MTL) during the early stages of Alzheimer’s Disease (AD) is limited by the presence of confounding non-AD pathologies and the two-dimensional (2-D) nature of conventional histology studies. Here, we combine ex vivo MRI and serial histological imaging from 25 human MTL specimens to present a detailed, 3-D characterization of quantitative NFT burden measures in the space of a high-resolution, ex vivo atlas with cytoarchitecturally-defined subregion labels, that can be used to inform future in vivo neuroimaging studies. Average maps show a clear anterior to poster gradient in NFT distribution and a precise, spatial pattern with highest levels of NFTs found not just within the transentorhinal region but also the cornu ammonis (CA1) subfield. Additionally, we identify granular MTL regions where measures of neurodegeneration are likely to be linked to NFTs specifically, and thus potentially more sensitive as early AD biomarkers. Using high-resolution ex vivo MRI and serial histology, Ravikumar et al. characterise 3D tau spread across histologically defined medial temporal lobe subregions thus providing a postmortem reference for in vivo studies on early Alzheimer’s disease.},
  doi = {10.1038/s41467-024-49205-0},
  pmid = {38839876},
  month = {06},
  journal = {Nature Communications},
  volume = {15},
  google_scholar_id = {tn5kj04AAAAJ},
  altmetric = {true},
  dimensions = {true},
  note = {Cited by 27},
  pdf = {https://www.nature.com/articles/s41467-024-49205-0.pdf},
}

@article{rdman2024postmortem,
  title = {Postmortem MRI signature of Hippocampal Sclerosis of Aging},
  author = {G. Rådman and Amanda E Denning and S. Ravikumar and Nicola Spotorno and R. Ittyerah and Lisa Levorse and M. Bedard and E. Chung and J. Robinson and T. Schuck and Eddie B. Lee and Sydney A. Lim and W. Trotman and A. Bahena and R. Olsen and David J. Irwin and María del Mar Arroyo Jiménez and Alicia Vela and Esther Buendia and Maria Mercedes Iniguez de Onzono Martin and M. Rabal and M. Muñoz and R. Insausti and Paul Yushkevich and L. Wisse},
  year = {2024},
  abstract = {Hippocampal Sclerosis of aging (HS) refers to age‐related selective neuronal loss and gliosis in hippocampal cornu ammonis 1 (CA1) and subiculum that is out of proportion to tau pathology in Alzheimer’s Disease (AD). HS is related to cognitive decline and memory impairments separately from other neurodegenerative pathologies. To date, in vivo imaging biomarkers of HS of aging are non‐existent, and their development would greatly improve diagnosis and prognosis in memory clinics. We therefore aimed to characterize the magnetic resonance imaging (MRI) signature of HS among autopsy confirmed cases of HS.},
  doi = {10.1002/alz.088849},
  month = {12},
  journal = {Alzheimer's & Dementia},
  volume = {20},
  google_scholar_id = {x-a4f8wAAAAJ},
  altmetric = {true},
  dimensions = {true},
}

@article{rovere2024clinical,
  title = {Clinical Manifestations.},
  author = {Rachel Rovere and Erin Liebenberg and Kimberly Halberstadter and David A. Wolk and Dawn J. Mechanic-Hamilton},
  year = {2024},
  abstract = {BACKGROUND
This study assesses the sensitivity of the mobile cognitive app performance platform (mCAPP), a mobile and engaging cognitive assessment tool, to participant sleep duration.


METHOD
The mCAPP includes three gamified tasks: a memory task ("Concentration"), a stroop-like task ("Brick Drop"), and a digit-symbol coding-like task ("Space Imposters"). For all games, shorter reaction times and fewer guesses indicates better performance. The cohort included 50 participants (72% female; age = 71.9±4.5; education = 16.8±2.3; 51% white; 49% Black/African American) without cognitive impairment who are enrolled in the Penn ADRC cohort. Sleep data was collected via actigraphy (Fitbit). Game performance and overnight sleep prior to gameplay were analyzed as a whole and grouped by fewer (quartile 1; Q1) and higher (quartile 4; Q4) minutes of sleep.


RESULT
The average number of minutes of sleep was 378.0±96.5. Overall, minutes of sleep showed a significant negative correlation with reaction time on Space Imposters (ρ = 0.001). Participants with the fewest minutes of nighttime sleep performed slower than those with the most sleep on Space Imposters (Q1 M = 2.73; Q4 M = 2.40; p<.001), Brick Drop (Q1 M = 1.58; Q4 M = 1.31; p = .004), and Concentration (Q1 M = 5.25; Q4 M = 5.02; p = .006). There was not a significant difference in number of errors on Space Imposters (p = 0.53) or Brick Drop (p = 0.45) when comparing performance of participants with lower and higher quartiles of sleep, but there was a significant difference in the number of guesses on Concentration (Q1 M = 14.91; Q4 M = 12.80; p = 0.01).


CONCLUSION
The mCAPP can remotely detect differences in cognitive performance related to nighttime sleep prior to gameplay. Future studies will examine differences in performance related to the time-of-day gameplay occurs (how long after overnight sleep) and whether performance is affected by daytime napping. A larger data set will also be used to fully determine the sensitivity of mCAPP to participant sleep duration and examine within-participant effects.},
