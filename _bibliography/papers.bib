	keywords = {(18)F-flortaucipir; AV1451; Amyloid negative; Amyloid positive; Atrophy; Braak stages; Logical memory; Medial temporal lobe; Subfield; Subregion; Tau PET; Volume},
	month = {Oct},
	number = {10},
	pages = {1286-1295},
	pmid = {31495603},
