	doi = {10.1038/s41467-022-28941-1},
	journal = {Nat Commun},
	journal-full = {Nature communications},
	mesh = {Alzheimer Disease; Amyloid beta-Peptides; Biomarkers; Brain; Cognitive Dysfunction; Humans; Magnetic Resonance Imaging; Neuroimaging; Positron-Emission Tomography; tau Proteins},
	month = {Mar},
	number = {1},
	pages = {1495},
	pmc = {PMC8938426},
	pmid = {35314672},
	pst = {epublish},
	title = {Dissociation of tau pathology and neuronal hypometabolism within the ATN framework of Alzheimer's disease},
	volume = {13},
