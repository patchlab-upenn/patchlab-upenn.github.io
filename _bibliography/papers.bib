@article{sadeghpour2024developing,
  title = {Developing an anatomically valid segmentation protocol for anterior regions of the medial temporal lobe},
  author = {Niyousha Sadeghpour and Sydney A. Lim and A. Wuestefeld and Amanda E Denning and R. Ittyerah and W. Trotman and E. Chung and S. Sadaghiani and K. Prabhakaran and M. Bedard and Daniel T. Ohm and E. Artacho-Pérula and Maria Mercedes Iniguez de Onzono Martin and M. Muñoz and Francisco Javier Molina Romero and José Carlos Delgado González and María del Mar Arroyo Jiménez and M. Rabal and Sandra Cebada Sanchez and Carlos de la Rosa Prieto and R. Insausti and C. Mcmillan and Murray Grossman and Eddie B. Lee and John A. Detre and J. Trojanowski and M. Tisdall and David J. Irwin and D. Wolk and Paul Yushkevich and L. Wisse},
  year = {2024},
  abstract = {The anterior portion of the MTL is one of the first regions targeted by pathology in sporadic Alzheimer’s disease (AD) indicating the potential for imaging metrics from this region to serve as valuable imaging biomarkers. However, most existing automated approaches for MTL segmentation do not incorporate anterior MTL subregions, and the few that do fail to account for its complex anatomical variability. Leveraging a unique postmortem dataset consisting of histology and structural MRI scans we aimed to develop an anatomically valid segmentation protocol for anterior entorhinal cortex (ERC), Brodmann Area (BA) 35, and BA36 and apply it for automated MTL segmentation of in vivo 3 tesla (T) MRI.},
  doi = {10.1002/alz.095375},
