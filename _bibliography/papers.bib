@article{ravikumar2021ex,
  title = {Ex vivo MRI atlas of the human medial temporal lobe: characterizing neurodegeneration due to tau pathology},
  author = {S. Ravikumar and L. Wisse and Sydney A. Lim and R. Ittyerah and L. Xie and M. Bedard and Sandhitsu R. Das and Eddie B. Lee and M. Tisdall and K. Prabhakaran and J. Lane and J. Detre and G. Mizsei and J. Trojanowski and John L. Robinson and T. Schuck and M. Grossman and E. Artacho-Pérula and Maria Mercedes Iñiguez de Onzoño Martin and María del Mar Arroyo Jiménez and M. Muñoz and Francisco Javier Molina Romero and Maria del Pilar Marcos Rabal and Sandra Cebada Sanchez and José Carlos Delgado González and C. de la Rosa Prieto and Marta Córcoles Parada and D. Irwin and D. Wolk and R. Insausti and Paul Yushkevich},
  year = {2021},
  abstract = {Tau neurofibrillary tangle (NFT) pathology in the medial temporal lobe (MTL) is closely linked to neurodegeneration, and is the early pathological change associated with Alzheimer’s disease (AD). To elucidate patterns of structural change in the MTL specifically associated with tau pathology, we compared high-resolution ex vivo MRI scans of human postmortem MTL specimens with histology-based pathological assessments of the MTL. MTL specimens were obtained from twenty-nine brain donors, including patients with AD, other dementias, and individuals with no known history of neurological disease. Ex vivo MRI scans were combined using a customized groupwise diffeomorphic registration approach to construct a 3D probabilistic atlas that captures the anatomical variability of the MTL. Using serial histology imaging in eleven specimens, we labelled the MTL subregions in the atlas based on cytoarchitecture. Leveraging the atlas and neuropathological ratings of tau and TAR DNA-binding protein 43 (TDP-43) pathology severity, morphometric analysis was performed to correlate regional MTL thickness with the severity of tau pathology, after correcting for age and TDP-43 pathology. We found significant correlations between tau pathology and thickness in the entorhinal cortex (ERC) and stratum radiatum lacunosum moleculare (SRLM). When focusing on cases with low levels of TDP-43 pathology, we found strong associations between tau pathology and thickness in the ERC, SRLM and the subiculum/cornu ammonis 1 (CA1) subfields of the hippocampus, consistent with early Braak stages.},
  doi = {10.1186/s40478-021-01275-7},
  pmid = {34689831},
  month = {10},
  journal = {Acta Neuropathologica Communications},
  volume = {9},
  google_scholar_id = {tn5kj04AAAAJ},
  altmetric = {true},
  dimensions = {true},
  note = {Cited by 42},
  pdf = {https://actaneurocomms.biomedcentral.com/track/pdf/10.1186/s40478-021-01275-7},
}

@article{ravikumar2021unfolding,
  title = {Unfolding the medial temporal lobe to characterize neurodegeneration due to Alzheimer's disease pathology},
  author = {S. Ravikumar and L. Wisse and Sydney A. Lim and R. Ittyerah and L. Xie and M. Bedard and Sandhitsu R. Das and D. Irwin and Eddie B. Lee and D. Tisdall and K. Prabhakaran and J. Detre and J. Trojanowski and John L. Robinson and T. Schuck and M. Grossman and G. Mizsei and E. Artacho-Pérula and Maria Mercedes Iniguez de Onzono Martin and María del Mar Arroyo Jiménez and M. Muñoz and Francisco Javier Molina Romero and Maria del Pilar Marcos Rabal and Sandra Cebada Sanchez and José Carlos Delgado González and C. de la Rosa Prieto and Marta Córcoles Parada and D. Wolk and R. Insausti and Paul Yushkevich},
  year = {2021},
  abstract = {Measurements of medial temporal lobe (MTL) neurodegeneration derived using MRI have been shown to be sensitive to changes during the early stages of AD. The specificity of these measurements to tau neurofibrillary tangle (NFT) pathology is limited by other frequently comorbid non‐AD factors which also cause structural changes in the MTL. Here, we directly link changes in MTL structure to underlying NFT pathology by combining ex vivo MRI with ratings of NFT severity derived from serial histology using a dataset of 18 human MTL specimens. We hypothesize that such an analysis can be used to define MTL “hotspots” where in vivo measures will be more sensitive to disease progression in preclinical AD than current state of the art biomarkers.},
  doi = {10.1002/alz.057622},
  month = {12},
  journal = {Alzheimer's & Dementia},
  volume = {17},
  google_scholar_id = {tn5kj04AAAAJ},
  altmetric = {true},
  dimensions = {true},
  pdf = {https://onlinelibrary.wiley.com/doi/pdfdirect/10.1002/alz.057622},
}

