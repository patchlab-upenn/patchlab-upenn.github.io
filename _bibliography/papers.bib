@article{flores2020neurodegeneration,
  title = {Neurodegeneration in medial temporal lobe subregions propagates within distinct functional networks in the AD continuum},
  author = {R. de Flores and Sandhitsu R. Das and L. Xie and L. Wisse and Preya Shah and Paul Yushkevich and D. Wolk},
