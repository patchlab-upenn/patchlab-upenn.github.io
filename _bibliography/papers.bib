@article{cousins2024combining,
  title = {Combining plasma biomarkers for β‐amyloid diagnosis and cognitive prognosis across the clinical spectrum: normal, amnestic, and non‐amnestic},
  author = {K. Cousins and J. Phillips and Sandhitsu R. Das and Kyra S O'Brien and T. Tropea and Alice Chen-Plotkin and L. Shaw and I. Nasrallah and Dawn J. Mechanic-Hamilton and C. Mcmillan and David J. Irwin and Eddie B. Lee and D. Wolk},
  year = {2024},
  abstract = {Alzheimer’s disease (AD) is clinically heterogeneous, and can manifest as amnestic or non‐amnestic dementia, or be pre‐manifest in persons with normal cognition (NormCog). Utility of plasma biomarkers to diagnose AD and prognose cognitive decline must be evaluated in a clinically heterogeneous population representative of the AD spectrum. We investigate pathological and cognitive correlates of plasma phosphorylated tau 181 (p‐tau181), glial fibrillary acidic protein (GFAP), and neurofilament light chain (NfL) across AD and AD‐related dementias (ADRD). We test 1.) if combing biomarkers improves diagnostic accuracy for β‐amyloid (Aβ) in NormCog and impaired cognition (ImpCog), 2.) if Aβ diagnostic accuracy in ImpCog differs by clinical syndrome (amnestic dementia vs. non‐amnestic dementia vs. mild cognitive impairment [MCI]), and 3.) how biomarkers predict future cognitive decline in Aβ+ and Aβ‐.},
  doi = {10.1002/alz.085075},
  month = {12},
  journal = {Alzheimer's & Dementia},
  volume = {20},
  google_scholar_id = {tn5kj04AAAAJ},
  altmetric = {true},
  dimensions = {true},
  pdf = {https://doi.org/10.1002/alz.085075},
}

