@article{taghvaei2024effects,
  title = {Effects of Amyloid Pathology and Vascular Risk Factors on Regional Cerebral Blood Flow Patterns},
  author = {M. Taghvaei and S. Sadaghiani and Banafsheh Shakibajahromi and Pulkit Khandelwal and Sandhitsu R. Das and I. Nasrallah and Paul Yushkevich and D. Wolk and John A. Detre and Sudipto Dolui},
