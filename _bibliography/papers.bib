	mesh = {Algorithms; Brain Mapping; Cognitive Dysfunction; Electronic Data Processing; Female; Hippocampus; Humans; Image Processing, Computer-Assisted; Learning; Magnetic Resonance Imaging; Male; Temporal Lobe},
