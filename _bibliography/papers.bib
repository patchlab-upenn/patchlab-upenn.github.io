}

@article{mccollum2020cognitive,
  title = {Cognitive and neurodegenerative profile differences between “mismatch MCI” (A+T‐N+ MCI) And “prodromal AD” (A+T+N+ MCI) increase with time},
  author = {Lauren McCollum and Sandhitsu R. Das and Jieqiong Wang and L. Xie and R. de Flores and L. Wisse and S. Xie and Paul Yushkevich and D. Wolk},
  year = {2020},
  abstract = {Per the Amyloid/Tau/Neurodegeneration (A/T/N) framework, beta‐amyloid accumulates during preclinical Alzheimer’s Disease (AD), followed by tau, then neurodegeneration. As AD symptoms are most linked to tau and neurodegeneration, both are expected by the MCI stage of disease. Thus, A+T‐N+ MCI (“mismatch MCI”) is thought to have both AD pathophysiology and non‐AD pathology, with the latter (given absence of tau) driving neurodegeneration and symptoms. We investigate the cognitive and neurodegenerative profile of mismatch MCI compared to “standard” A+T+N+ MCI (“prodromal AD”).},
  doi = {10.1002/alz.046030},
