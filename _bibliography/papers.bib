  author = {L. Xie and Sandhitsu R. Das and Yue Li and L. Wisse and E. McGrew and Xueying Lyu and M. Dicalogero and Ujashi Shah and Ademola Ilesanmi and Amanda E Denning and Christopher D. Brown and Jesse S Cohen and Lasya P. Sreepada and M. Dong and Niyousha Sadeghpour and Pulkit Khandelwal and R. Ittyerah and S. Ravikumar and S. Sadaghiani and S. Hrybouski and R. de Flores and Eli Gibson and Paul Yushkevich and D. Wolk},
  year = {2024},
  abstract = {The medial temporal lobe's (MTL) early involvement in tau pathology makes it a key focus in the development of preclinical Alzheimer’s disease (AD) biomarkers. ROI analyses in prior studies reported significant MTL structural differences in cognitively normal individuals with and without ß‐amyloid (A+/‐CN). Pointwise analysis, offering spatial information of early neurodegeneration, has potential to pinpoint “signature regions” of pathological change, but has been underexplored in the MTL. This study employs a specialized pointwise analysis pipeline to examine the spatial pattern of MTL structural change in subgroups dichotomized by both ß‐amyloid and tau status in a large cohort of CN individuals.},
  doi = {10.1002/alz.093969},
  month = {12},
  journal = {Alzheimer's & Dementia},
  volume = {20},
  google_scholar_id = {tn5kj04AAAAJ},
  altmetric = {true},
  dimensions = {true},
  pdf = {https://doi.org/10.1002/alz.093969},
}

@article{xie2024utilizing,
  title = {Utilizing Advanced Artificial Intelligence for Automated Detection and Segmentation of Amyloid‐Related Imaging Abnormality (ARIA)},
  author = {L. Xie and Paul Yushkevich and Sandhitsu R. Das and D. Wolk and Eli Gibson},
  year = {2024},
