@article{fischer2025exploring,
  title = {Exploring the Influence of SSDOH and Self‐Identified Race on Resilience and Vulnerability using Machine Learning for NACC UDS},
  author = {E. Fischer and Zahra Khodakarami and Christopher A. Brown and D. Mechanic‐Hamilton and Paul Yushkevich and Sandhitsu R. Das and D. Wolk},
  year = {2025},
  abstract = {Current cognitive analysis methods in neurodegenerative disease rely on the use of individual neuropsychological assessments, which can be subject to variation and bias. A potentially more robust way to represent cognitive status is to use a cognitive age model to predict an individual's age from their cognitive assessment scores and demographics. This modeling allows for identification of individuals exhibiting resilience or vulnerability to normal aging processes across diverse datasets.},
  doi = {10.1002/alz70857_105739},
  month = {12},
  journal = {Alzheimer's & Dementia},
  volume = {21},
