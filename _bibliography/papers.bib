@article{das2021tauatrophy,
  title = {Tau‐Atrophy Variability Reveals Phenotypic Heterogeneity in Alzheimer's Disease},
  author = {Sandhitsu R. Das and Xueying Lyu and M. Duong and L. Xie and Lauren McCollum and R. de Flores and M. Dicalogero and D. Irwin and B. Dickerson and I. Nasrallah and Paul Yushkevich and D. Wolk},
