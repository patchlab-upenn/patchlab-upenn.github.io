  year = {2021},
  abstract = {In clinical trials targeting early Alzheimer’s disease (AD), recruiting participants that are more likely to progress over the course of the trials is crucial to success. Molecular and neurodegenerative markers obtained through PET or in cerebrospinal fluid have significant prognostic value, but they are costly or invasive. In this study, we hypothesize that a combination of plasma and structural MRI biomarkers, which overcome these limitations, are predictive of longitudinal progression measured by atrophy and cognitive decline in early AD, providing a more feasible solution.},
