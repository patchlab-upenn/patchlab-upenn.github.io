@inproceedings{hao25,
	abstract = {4D cardiac imaging offers impactful insights into structural heart dynamics. However, analyzing 4D data using conventional 3D software tools requires additional effort. This paper introduces three natively 4D-optimized software applications we have developed: ITK-SNAP 4 for 4D image I/O, visualization, and segmentation; Greedy Propagation for intra-series registration and creation of 4D segmentation from sparse 3D segmentations; and Scherzo for fast web-based 4D model generation and visualization. These open-source tools provide a streamlined user experience, comprehensive features, and broad file type support including common 4D cardiac image formats. Experiments on core features demonstrate feasibility and consistency.},
	address = {Cham},
	author = {Hao, Jilei and Yushkevich, Paul A. and Dong, Ningjun J. and Amin, Silvani and Guo, Zaiyang and Yushkevich, Natalie and Aggarwal, Ankush and Pouch, Alison M.},
	booktitle = {Functional Imaging and Modeling of the Heart},
	date-added = {2026-03-25 15:12:59 -0400},
